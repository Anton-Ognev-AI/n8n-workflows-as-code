# Copy this file to .env and fill in real values. .env is gitignored and is
# read only at deploy time by the deployer scripts — never committed, never
# passed to the LLM. Credentials are stored inside n8n and referenced by ID.

# Base URL of your n8n instance (scheme + host; the scripts derive /api/v1 from it)
N8N_URL=https://n8n.example.com

# n8n public API key (Settings -> API in the n8n UI)
N8N_API_KEY=your-n8n-api-key

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Telegram chat/channel ID the daily messages are sent to
TELEGRAM_CHAT_ID=your-telegram-chat-id
